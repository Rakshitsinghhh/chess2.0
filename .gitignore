# =========================
# 🐍 Python
# =========================
__pycache__/
*.pyc
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/

# Virtual environments
.venv/
venv/
env/

# =========================
# 📦 Data & Outputs
# =========================

# Ignore all data files
data/*
!data/.gitkeep

# Ignore outputs generally
outputs/*
!outputs/.gitkeep

# Allow models folder structure
!outputs/models/
!outputs/models/.gitkeep

# Allow ONLY .pt models inside models folder
!outputs/models/*.pt

# Ignore logs
outputs/logs/*
!outputs/logs/.gitkeep

# =========================
# 🤖 ML Models (global rule)
# =========================

# Track .pt using Git LFS (not normal git)
# (LFS will handle these)
*.pt

# Ignore ONNX (large exports)
*.onnx

# =========================
# 🌐 Node / Frontend
# =========================
node_modules/
.next/
out/
*.tsbuildinfo

# =========================
# 🔐 Environment files
# =========================
.env
.env.local
.env.*.local

# =========================
# 🧠 IDE / Editor
# =========================
.vscode/
.idea/

# =========================
# 🧾 Misc
# =========================
.DS_Store
*.log