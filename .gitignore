# Ignore virtual environment
.venv/

# Ignore data folder (all files)
data/*
!data/.gitkeep

# Ignore PyTorch model files everywhere
*.pt

# Exported ONNX (large); generate with scripts/export_model_onnx.py
*.onnx

# Ignore large model shards inside outputs/models
outputs/models/*

# (Optional) keep folder structure
!outputs/models/.gitkeep

# Ignore logs if needed
outputs/logs/*
!outputs/logs/.gitkeep

# Ignore Python cache
__pycache__/
*.pyc

# Node / Next.js
node_modules/
.next/
out/
*.tsbuildinfo
.env
.env.local
.env*.local
.vercel
