# ─── FastAPI model server URL ─────────────────────────────────────────────────
# Local dev: the Python server running on your machine
MODEL_SERVER_URL=http://127.0.0.1:8001

# Production (Railway/Render/Fly.io): paste your deployed URL here
# MODEL_SERVER_URL=https://chess2-model-server.railway.app

# ─── ONNX fallback (runs inference in Vercel without an external server) ──────
# When USE_ONNX=1, Next.js API routes use onnxruntime-node (no Python needed).
# Export the model first:  python scripts/export_onnx.py
# Then place model.onnx in nextjs_host/public/  OR set MODEL_ONNX_URL below.
USE_ONNX=0
# MODEL_ONNX_URL=https://huggingface.co/your-user/chess2.0/resolve/main/model.onnx

# ─── Model server env vars (used in Dockerfile / Railway) ────────────────────
# MODEL_URL=https://huggingface.co/your-user/chess2.0/resolve/main/latest.pt
# MODEL_PATH=/app/outputs/models/latest.pt
# HF_TOKEN=hf_xxxx       # only needed if the HF repo is private
# FAST_MODE=1             # 1 = fast argmax inference (default), 0 = full beam
